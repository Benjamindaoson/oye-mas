# 4 个 Agent worker 共用镜像(消费 Redis Streams)
# 用 ARG AGENT_KIND={text|document|image|av} 决定启动哪个
ARG AGENT_KIND=text

FROM python:3.12-slim AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends build-essential gcc curl \
    && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:0.5.9 /uv /uvx /usr/local/bin/
COPY youle/backend/pyproject.toml youle/backend/uv.lock ./
RUN uv venv /opt/venv && \
    UV_PROJECT_ENVIRONMENT=/opt/venv uv sync --frozen --no-dev --no-install-project

FROM python:3.12-slim AS runtime
ARG AGENT_KIND

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r app && useradd -r -g app -u 10001 app

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app \
    AGENT_KIND=${AGENT_KIND}

WORKDIR /app
COPY --chown=app:app youle/backend/app /app/app
COPY --chown=app:app youle/agents /app/agents
COPY --chown=app:app youle/skills /app/skills

USER app

# liveness:是否能启动 Python(具体心跳走 Redis Stream agent_heartbeats)
HEALTHCHECK --interval=20s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

# 用 entrypoint 选 agent
COPY <<'EOF' /app/entrypoint.sh
#!/bin/sh
case "${AGENT_KIND:-text}" in
  text)     exec python -m agents.text.main ;;
  document) exec python -m agents.document.main ;;
  image)    exec python -m agents.image.main ;;
  av)       exec python -m agents.av.main ;;
  *) echo "unknown AGENT_KIND=${AGENT_KIND}"; exit 1 ;;
esac
EOF
USER root
RUN chmod +x /app/entrypoint.sh
USER app

CMD ["/app/entrypoint.sh"]
