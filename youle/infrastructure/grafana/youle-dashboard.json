{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "意图理解 p95 延迟",
      "targets": [{ "expr": "youle_intent_latency_seconds{quantile=\"0.95\"}", "legendFormat": "p95" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red",    "value": 1.5 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 }
    },
    {
      "type": "timeseries",
      "title": "Agent 队列积压(按 agent)",
      "targets": [{ "expr": "youle_agent_queue_pending", "legendFormat": "{{agent}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 5 }
    },
    {
      "type": "stat",
      "title": "HITL 未关闭门",
      "targets": [{ "expr": "youle_hitl_open_total" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 }
    },
    {
      "type": "stat",
      "title": "视频任务 24h 成功率",
      "targets": [{
        "expr": "youle_video_task_success_total / (youle_video_task_success_total + youle_video_task_failed_total)",
        "legendFormat": "成功率"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green",  "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 5, "w": 8, "h": 5 }
    },
    {
      "type": "piechart",
      "title": "Agent 状态分布",
      "targets": [{
        "expr": "sum by (status) (youle_agent_status)",
        "legendFormat": "{{status}}"
      }],
      "gridPos": { "x": 8, "y": 5, "w": 8, "h": 5 }
    },
    {
      "type": "timeseries",
      "title": "DLQ 累积(按 agent)",
      "targets": [{ "expr": "youle_dlq_total", "legendFormat": "{{agent}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 5 }
    },
    {
      "type": "timeseries",
      "title": "任务状态(过去 24h)",
      "targets": [{
        "expr": "youle_tasks_total",
        "legendFormat": "{{status}}"
      }],
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 7 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["youle", "v1"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "「有了」V1 SLO 大盘",
  "uid": "youle-v1-slo",
  "version": 1
}
