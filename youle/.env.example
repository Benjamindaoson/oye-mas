# ============================
# 环境
# ============================
ENV=dev                                # dev / staging / prod
LOG_LEVEL=INFO
DEBUG=true

# ============================
# 数据库
# ============================
DATABASE_URL=postgresql+asyncpg://youle:youle_dev@localhost:5432/youle
POSTGRES_USER=youle
POSTGRES_PASSWORD=youle_dev
POSTGRES_DB=youle

# ============================
# Redis(缓存 / 队列 / Celery broker)
# ============================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================
# OSS(dev: MinIO,prod: 阿里云 OSS)
# ============================
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=youle-dev
OSS_REGION=cn-hangzhou
OSS_USE_SSL=false

# ============================
# Qdrant
# ============================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================
# LiteLLM(走 mock 时不需要 key)
# ============================
LITELLM_URL=http://localhost:4000
LITELLM_API_KEY=sk-mock-1234
LITELLM_MOCK=true

# ============================
# 外部服务(dev 全 mock,留 placeholder)
# ============================
TAVILY_API_KEY=
ALIYUN_ACCESS_KEY=
ALIYUN_SECRET_KEY=
ALIYUN_SMS_SIGN=
ALIYUN_OSS_BUCKET=
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_TOKEN=

# ============================
# 鉴权
# ============================
JWT_SECRET=change_me_to_a_long_random_string_in_prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72
SMS_DEV_MODE=true                      # dev 直接 console.log 验证码

# ============================
# CORS / WebSocket
# ============================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WS_HEARTBEAT_SECONDS=30

# ============================
# Sentry(prod 才启)
# ============================
SENTRY_DSN=

# ============================
# 前端
# ============================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
